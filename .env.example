# ============ Casper / Odra livenet (Rust CLI: deploy, attest, fund) ============
# Get testnet CSPR: https://testnet.cspr.live/tools/faucet
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=./keys/deployer/secret_key.pem
# CSPR.cloud node (recommended, needs free auth token from console.cspr.cloud):
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.cspr.cloud
ODRA_CASPER_LIVENET_EVENTS_URL=https://node.testnet.cspr.cloud/events
# CSPR_CLOUD_AUTH_TOKEN=
# Public node alternative (verify during spike; livenet may want base URL without /rpc):
# ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.casper.network/rpc
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test

# ============ Shared chain config (Node services) ============
RPC_URL=https://node.testnet.casper.network/rpc
CAIP2_CHAIN_ID=casper:casper-test
# Filled after scripts/deploy-token.sh:
TOKEN_PACKAGE_HASH=
TOKEN_NAME=OjaToken
TOKEN_SYMBOL=OJA
TOKEN_DECIMALS=9
# Filled after contracts deploy_registry:
REGISTRY_ADDRESS=

# ============ Facilitator ============
# Sponsored CSPR.cloud facilitator (recommended: they pay settlement gas; the
# free tier at console.cspr.build includes 1,000 testnet settlements/month):
FACILITATOR_URL=https://x402-facilitator.cspr.cloud
FACILITATOR_API_KEY=
# Self-hosted fallback (gas comes from your deployer key; leave API key empty):
# FACILITATOR_URL=http://localhost:4022
FACILITATOR_PORT=4022
CASPER_NETWORKS=casper:casper-test
# Gas limit per settlement; measured consumption ~2.72 CSPR on casper-test:
TRANSACTION_PAYMENT_MOTES=4000000000
SECRET_KEY_PEM_CASPER_CASPER_TEST="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
SECRET_KEY_ALGO_CASPER_CASPER_TEST=ed25519
RPCURL_CASPER_CASPER_TEST=https://node.testnet.casper.network/rpc

# ============ Provider (paid endpoints) ============
PROVIDER_PORT=4021
# x402 Casper address of the provider wallet: "00" + account hash hex
# (keys/deployer/account_hash.txt without the "account-hash-" prefix), NOT the public key:
PAYEE_ADDRESS=
ADMIN_TOKEN=change-me-long-random

# ============ Indexer ============
INDEXER_PORT=4030
INDEXER_URL=http://localhost:4030
DB_PATH=./data/oja.sqlite

# ============ Pricing agent ============
PRICE_LADDER_MOTES=500000000,1000000000,2000000000,3000000000,5000000000,8000000000,12000000000
WINDOW_SECONDS=45
EXPLORATION_EPSILON=0.2
# Rust livenet bin on Linux/macOS; the casper-js-sdk port works everywhere:
ATTESTOR_BIN=./scripts/livenet/attest.mjs
# ATTESTOR_BIN=./contracts/target/release/attest
# Optional LLM narration (OpenAI-compatible; DeepSeek works):
# LLM_BASE_URL=https://api.deepseek.com
# LLM_API_KEY=
# LLM_MODEL=deepseek-chat

# ============ Buyer fleet ============
BUYER_COUNT=6
BUYER_KEYS_DIR=./keys/buyers
BUYER_MEAN_VALUATION_MOTES=4000000000
BUYER_TICK_MS=6000
PROVIDER_URL=http://localhost:4021
